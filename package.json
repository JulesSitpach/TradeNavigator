{
  "name": "trade-navigator",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx --require tsconfig-paths/register server/index.ts",
    "dev:alt": "node dev-esbuild.js",
    "dev:firebase": "firebase emulators:start --only functions,hosting",
    "build": "vite build && node esbuild.config.js && npm run build:firebase",
    "build:firebase": "node scripts/prepare-firebase.js",
    "start": "NODE_ENV=production node dist/index.js",
    "deploy": "firebase deploy",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "test:startup": "node scripts/test-server-startup.js",
    "check": "tsc",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit push:pg",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run unit",
    "test:integration": "vitest run integration",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:changed": "eslint $(git diff --cached --name-only --diff-filter=ACMR | grep -E '\\.(ts|tsx|js|jsx)$')",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:changed": "prettier --write $(git diff --cached --name-only --diff-filter=ACMR | grep -E '\\.(ts|tsx|js|jsx|json|md)$')",
    "setup": "bash ./scripts/setup.sh",
    "ci": "bash ./scripts/ci.sh",
    "prepare": "cp ./scripts/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
  },
